<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financeiro - Cadastro de Vendas</title>
    <link rel="stylesheet" href="style-financeiro.css">
</head>
<body>

    <div class="container">
        <form id="form-venda">
            <h2>Lançar Nova Venda</h2>
            
            <div class="input-group">
                <label for="cliente">Cliente</label>
                <input type="text" id="cliente" placeholder="Nome do cliente" required>
            </div>

            <div class="input-group">
                <label for="produto">Produto/Serviço</label>
                <input type="text" id="produto" placeholder="O que foi vendido?" required>
            </div>

            <div class="row">
                <div class="input-group">
                    <label for="valor">Valor (R$)</label>
                    <input type="number" id="valor" step="0.01" placeholder="0,00" required>
                </div>
                <div class="input-group">
                    <label for="data">Data</label>
                    <input type="date" id="data" required>
                </div>
            </div>

            <button type="submit">Registrar Venda</button>
        </form>
    </div>

    <div class="container-lista">
        <h3>Histórico de Vendas</h3>
        <table id="tabela-vendas">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Cliente</th>
                    <th>Produto</th>
                    <th>Valor</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                </tbody>
        </table>
    </div>

    <script src="script-financeiro.js"></script>
</body>
</html>